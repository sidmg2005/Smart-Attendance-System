<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🔹 Internet for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 🔔 NEW: Notification Permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- 🔹 Camera Permission -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 🔹 Storage permission -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 🔹 Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 🔹 Optional biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- 🔹 Camera hardware -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Hostel"
        tools:targetApi="34">

        <!-- 🔔 NEW: Firebase Messaging Service -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>

        <activity
            android:name=".Notification"
            android:exported="false" />

        <!-- 🔹 Main Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🔹 Login -->
        <activity
            android:name=".login"
            android:exported="false" />

        <!-- 🔹 Admin Panel -->
        <activity
            android:name=".AdminHome"
            android:exported="false" />

        <!-- 🔹 Student Attendance -->
        <activity
            android:name=".Student_Attendance"
            android:exported="false" />

        <!-- 🔹 Face Authentication -->
        <activity
            android:name=".face_auth"
            android:exported="false" />

        <!-- 🔹 Student Registration -->
        <activity
            android:name=".StudentRegister"
            android:exported="false" />

        <!-- 🔹 Attendance Report -->
        <activity
            android:name=".StudentReport"
            android:exported="false" />

        <!-- ✅ Present / Absent -->
        <activity
            android:name=".Present"
            android:exported="false" />

        <activity
            android:name=".Absent"
            android:exported="false" />

        <activity
            android:name=".adminreport"
            android:exported="false" />

    </application>

</manifest>